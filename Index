      ${c.nova>0?`<button class="btn gold block" style="margin-top:14px" onclick="addFilmWords('${f.id}')">+ Estudar as ${c.nova} palavras novas</button>`:''}
      <button class="btn ghost block" style="margin-top:8px" onclick="genGrammarForFilm('${f.id}')">✏️ Gerar teste gramatical deste título</button>
    </div>

    <div class="card pad">
      <h3 style="font-size:1.1rem;margin-bottom:12px">Vocabulário do filme</h3>
      ${c.items.map(w=>`<div class="row-item">
        <div class="grow"><div class="t">${dispWord(w)}</div><div class="d">${esc(w.back)}${w.example?` — <i>${esc(w.example)}</i>`:''}</div></div>
        ${chip(w.status)}
      </div>`).join('')}
    </div>
    <p class="muted" style="font-size:.74rem;margin-top:10px">A % se recalcula sozinha conforme você domina mais cards — reabra o filme depois de estudar pra ver subir.</p>`;
}

function addFilmWords(id){
  const l=curLang();const f=l.films.find(x=>x.id===id);if(!f)return;
  const c=classifyFilm(f,l);
  session.genCards=c.items.filter(w=>w.status==='nova').map(w=>({...w,pick:true}));
  if(!session.genCards.length){toast('Nenhuma palavra nova');return}
  modal(`<h3>Adicionar ao baralho</h3>
    <p class="muted" style="font-size:.86rem;margin-bottom:14px">Estas palavras novas vão entrar na sua repetição espaçada. Desmarque o que não quiser.</p>
    <div style="max-height:46vh;overflow-y:auto">
    ${session.genCards.map((w,i)=>`<label class="row-item" style="cursor:pointer">
      <input type="checkbox" checked onchange="session.genCards[${i}].pick=this.checked" style="width:18px;height:18px;accent-color:var(--petrol)">
      <div class="grow"><div class="t">${esc(w.front)}</div><div class="d">${esc(w.back)}</div></div>
    </label>`).join('')}
    </div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn ghost block" onclick="closeModal()">Cancelar</button>
      <button class="btn block gold" onclick="addGenCards();openFilm('${id}')">Adicionar selecionados</button>
    </div>`);
}
function delFilm(id){const l=curLang();l.films=l.films.filter(f=>f.id!==id);save();renderMedia();toast('Filme removido')}

/* =========================================================
   RECOMENDAÇÕES — catálogo por provedor + idioma (backend)
   ========================================================= */
