   FILMES & SÉRIES — vocabulário + cobertura
   ========================================================= */
function filmRec(o){return {id:uid(),title:o.title,note:o.note||'',source:o.source||'name',words:o.words||[]}}

/* ---- algoritmo: índice de conhecimento a partir de TODO o conteúdo ---- */
function normWord(s){
  return (s||'').toLowerCase()
    .replace(/\([^)]*\)/g,' ')              // remove romanização entre parênteses
    .replace(/[^\p{L}\p{N}\s]/gu,' ')        // remove pontuação
    .replace(/\s+/g,' ').trim();
}
function tokenize(s){return normWord(s).split(' ').filter(t=>t.length>1)}
function stemLatin(w){
  if(w.length<5)return w;
  return w.replace(/(mente|ções|ção|ndo|ado|ada|ados|adas|ing|ed|s|mos|emos|amos)$/,'');
}
function cardMastered(c){return (c.interval>=21)||(c.reps>=4)}

/* nível 2 = domino, 1 = conheço/em aprendizado, 0 = novo */
function buildKnowledge(l){
  const idx=new Map();
  const put=(tok,lvl)=>{
    if(!tok)return;
    if((idx.get(tok)||0)<lvl)idx.set(tok,lvl);
    const st=stemLatin(tok);
    if(st&&st!==tok&&(idx.get(st)||0)<lvl)idx.set(st,lvl);
  };
  // 1) flashcards: termo + exemplos
  l.vocab.forEach(c=>{
    const lvl=cardMastered(c)?2:1;
    tokenize(c.front).forEach(t=>put(t,lvl));
    tokenize(c.example).forEach(t=>put(t,1)); // exposição em exemplo
  });
  // 2) músicas que você traduziu (exposição)
  (l.songs||[]).forEach(s=>{if(s.transLines)tokenize(s.lyrics).forEach(t=>put(t,1))});
  // 3) filmes já estudados (palavras adicionadas voltam pelos cards; exemplos contam)
  return idx;
}
function wordStatus(word,idx){
  const toks=tokenize(word);
  if(!toks.length)return 'nova';
  let lvl=0;
  toks.forEach(t=>{let v=idx.get(t)||idx.get(stemLatin(t))||0;if(v>lvl)lvl=v});
  return lvl===2?'sei':lvl===1?'aprendendo':'nova';
}
function classifyFilm(film,l){
  const idx=buildKnowledge(l);
  const items=film.words.map(w=>({...w,status:wordStatus(w.front,idx)}));
  const sei=items.filter(i=>i.status==='sei').length;
  const apr=items.filter(i=>i.status==='aprendendo').length;
  const nova=items.filter(i=>i.status==='nova').length;
  const total=items.length||1;
  const pct=Math.round(((sei+apr*0.5)/total)*100);
  return {items,sei,apr,nova,total:items.length,pct};
}

