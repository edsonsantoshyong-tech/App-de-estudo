  r.readAsText(file);
}
function confirmReset(){
  modal(`<h3>Apagar tudo?</h3><p class="muted" style="margin-bottom:16px">Isso remove seu perfil, idiomas e progresso deste navegador. Esta ação não pode ser desfeita.</p>
    <div style="display:flex;gap:8px"><button class="btn ghost block" onclick="closeModal()">Cancelar</button>
    <button class="btn block" style="background:var(--warn)" onclick="doReset()">Apagar tudo</button></div>`);
}
function doReset(){localStorage.removeItem(STORE_KEY);location.reload()}

/* =========================================================
   MÚSICA — trecho + tradução + flashcards por IA
   ========================================================= */
function parseYouTube(url){
  if(!url)return null;
  let m=url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([\w-]{11})/);
  if(!m)return null;
  let t=0;const tm=url.match(/[?&]t=(\d+)/);if(tm)t=parseInt(tm[1]);
  return {id:m[1],t};
}

function renderMusic(){
  const l=curLang();
  const el=document.getElementById('view-music');
  if(!l.songs||l.songs.length===0){
    el.innerHTML=section('Música',l)+`
      <button class="btn block gold" style="margin-bottom:14px" onclick="openSongModal()">+ Adicionar música</button>
      <div class="card pad empty"><div class="big">🎵</div>
        <h3 style="color:var(--petrol)">Aprenda com suas músicas</h3>
        <p class="muted" style="margin:8px 0 0">Cole a letra, escolha um trecho do YouTube e deixe a IA traduzir e criar os flashcards.</p>
      </div>`;
    return;
  }
  el.innerHTML=section('Música',l)+`
    <button class="btn block gold" style="margin-bottom:14px" onclick="openSongModal()">+ Adicionar música</button>
    ${l.songs.map(s=>`<div class="row-item" style="cursor:pointer" onclick="openSong('${s.id}')">
      <div style="font-size:1.4rem">🎵</div>
      <div class="grow"><div class="t">${esc(s.title)}</div><div class="d">${esc(s.artist||'—')}</div></div>
      <button class="icon-btn" onclick="event.stopPropagation();openSongModal('${s.id}')">✏️</button>
      <button class="icon-btn" onclick="event.stopPropagation();delSong('${s.id}')">🗑️</button>
    </div>`).join('')}`;
}

function openSong(id){
  const l=curLang();const s=l.songs.find(x=>x.id===id);if(!s)return;
  session.song=s;
  const el=document.getElementById('view-music');
  const yt=parseYouTube(s.youtube);
  let player='';
  if(yt){
    const start=s.start||yt.t||0;
    const q=`start=${start}${s.end?`&end=${s.end}`:''}&rel=0`;
    player=`<div style="position:relative;width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;margin-bottom:14px;background:#000">
      <iframe id="ytFrame" width="100%" height="100%" style="border:0"
        src="https://www.youtube.com/embed/${yt.id}?${q}"
        allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"
        allowfullscreen></iframe></div>
      ${s.start||s.end?`<p class="muted" style="font-size:.76rem;margin:-6px 0 14px">Trecho: ${fmtSec(s.start||0)}${s.end?' – '+fmtSec(s.end):''}</p>`:''}`;
  }
  el.innerHTML=`
    <div class="section-h"><div><div class="eyebrow">${l.flag} ${esc(l.name)}</div><h2 style="font-size:1.35rem">${esc(s.title)}</h2>
      <p class="muted" style="font-size:.9rem">${esc(s.artist||'')}</p></div>
      <button class="btn ghost sm" onclick="go('music')">‹ Voltar</button></div>
    ${player}
    <div class="card pad" style="margin-bottom:14px">
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
        <button class="btn sm ${s.transLines?'ghost':'gold'}" id="btnTrad" onclick="translateSong('${s.id}')">
          ${s.transLines?'Ocultar tradução':'🌐 Traduzir letra'}</button>
        <button class="btn sm" onclick="genFlashcards('${s.id}')">✨ Gerar flashcards</button>
      </div>
      <div id="lyrics">${renderLyrics(s)}</div>
    </div>
    <p class="muted" style="font-size:.74rem">Tradução e flashcards são gerados pela IA (funciona no preview do claude.ai). A letra é o conteúdo que você inseriu.</p>`;
}

function renderLyrics(s){
  if(!s.lyrics.trim())return '<p class="muted">Sem letra cadastrada. Edite a música para colar a letra.</p>';
  const lines=s.lyrics.split('\n');
  return lines.map((ln,i)=>{
    if(!ln.trim())return '<div style="height:10px"></div>';
    const tr=(s.transLines&&s.transLines[i])?`<div style="font-size:.82rem;color:var(--gold);font-style:italic">${esc(s.transLines[i])}</div>`:'';
    return `<div style="padding:6px 0;border-bottom:1px dashed var(--line)">
      <div style="font-weight:500">${esc(ln)}</div>${tr}</div>`;
  }).join('');
}
function fmtSec(s){s=parseInt(s)||0;const m=Math.floor(s/60),x=s%60;return m+':'+String(x).padStart(2,'0')}

async function translateSong(id){
  const l=curLang();const s=l.songs.find(x=>x.id===id);if(!s)return;
  if(s.transLines){s.transLines=null;save();openSong(id);return} // toggle off
  if(!s.lyrics.trim()){toast('Cole a letra primeiro');return}
  const btn=document.getElementById('btnTrad');btn.disabled=true;btn.textContent='Traduzindo...';
  const lines=s.lyrics.split('\n');
  const sys=`Traduza para português brasileiro cada linha da letra de música em ${l.name}.
Responda APENAS com um array JSON de strings, sem markdown, com EXATAMENTE ${lines.length} itens, na mesma ordem.
Para linhas vazias, retorne string vazia "". Não adicione comentários.`;
  try{
    const numbered=lines.map((ln,i)=>`${i}: ${ln}`).join('\n');
    const data=await callClaude(sys,[{role:'user',content:numbered}]);
    let txt=extractText(data).replace(/```json|```/g,'').trim();
    let arr=JSON.parse(txt);
    if(!Array.isArray(arr))throw 0;
    s.transLines=lines.map((_,i)=>arr[i]||'');
    save();openSong(id);
  }catch(e){
    toast('Não foi possível traduzir agora');
    btn.disabled=false;btn.textContent='🌐 Traduzir letra';
  }
}

async function genFlashcards(id){
  const l=curLang();const s=l.songs.find(x=>x.id===id);if(!s)return;
  if(!s.lyrics.trim()){toast('Cole a letra primeiro');return}
  modal(`<h3>Gerando flashcards…</h3><div style="text-align:center;padding:20px">
    <span class="typing"><i></i><i></i><i></i></span>
    <p class="muted" style="margin-top:12px">A IA está escolhendo o vocabulário útil da música.</p></div>`);
  const sys=`Você cria flashcards de vocabulário de ${l.name} para um falante de português brasileiro, a partir da letra de uma música.
Escolha entre 8 e 12 palavras ou expressões úteis e frequentes que aparecem NA letra (não invente).
Responda APENAS com um array JSON, sem markdown, no formato:
[{"front":"palavra/expressão em ${l.name}","back":"tradução em português","example":"a linha da música onde aparece"}]`;
  try{
    const data=await callClaude(sys,[{role:'user',content:s.lyrics}]);
    let txt=extractText(data).replace(/```json|```/g,'').trim();
    let arr=JSON.parse(txt);
    if(!Array.isArray(arr)||!arr.length)throw 0;
    session.genCards=arr.filter(c=>c.front&&c.back).map(c=>({...c,pick:true}));
    showGenPreview(s);
  }catch(e){
    modal(`<h3>Ops</h3><p class="muted" style="margin-bottom:16px">Não consegui gerar os flashcards agora. A geração por IA funciona no preview do claude.ai.</p>
      <button class="btn block" onclick="closeModal()">Fechar</button>`);
  }
}

function showGenPreview(s){
  const cards=session.genCards;
  modal(`<h3>Flashcards de "${esc(s.title)}"</h3>
    <p class="muted" style="font-size:.86rem;margin-bottom:14px">Desmarque o que não quiser. Os escolhidos vão para o baralho.</p>
    <div style="max-height:46vh;overflow-y:auto">
    ${cards.map((c,i)=>`<label class="row-item" style="cursor:pointer">
      <input type="checkbox" ${c.pick?'checked':''} onchange="session.genCards[${i}].pick=this.checked" style="width:18px;height:18px;accent-color:var(--petrol)">
      <div class="grow"><div class="t">${esc(c.front)}</div><div class="d">${esc(c.back)}</div></div>
    </label>`).join('')}
    </div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn ghost block" onclick="closeModal()">Cancelar</button>
      <button class="btn block gold" onclick="addGenCards()">Adicionar selecionados</button>
    </div>`);
}
function addGenCards(){
  const l=curLang();let n=0;
  session.genCards.filter(c=>c.pick).forEach(c=>{l.vocab.push(vcard(c.front,c.back,c.example||''));n++});
  save();closeModal();toast(`${n} card(s) adicionados ao baralho`);
}

/* ---- editor de música ---- */
function openSongModal(id){
  const l=curLang();const s=id?l.songs.find(x=>x.id===id):null;
  modal(`<h3>${s?'Editar':'Nova'} música</h3>
    <label class="field"><span>Título</span><input id="s_title" class="input" value="${s?esc(s.title):''}" placeholder="Nome da música"></label>
    <label class="field"><span>Artista (opcional)</span><input id="s_artist" class="input" value="${s?esc(s.artist):''}"></label>
    <label class="field"><span>Link do YouTube (opcional)</span><input id="s_yt" class="input" value="${s?esc(s.youtube):''}" placeholder="https://youtube.com/..."></label>
    <div style="display:flex;gap:10px">
      <label class="field" style="flex:1"><span>Início do trecho (s)</span><input id="s_start" type="number" min="0" class="input" value="${s?s.start||'':''}" placeholder="ex: 45"></label>
      <label class="field" style="flex:1"><span>Fim do trecho (s)</span><input id="s_end" type="number" min="0" class="input" value="${s?s.end||'':''}" placeholder="ex: 75"></label>
    </div>
    <label class="field"><span>Letra (cole aqui)</span><textarea id="s_lyrics" class="input" style="min-height:130px">${s?esc(s.lyrics):''}</textarea></label>
    <div style="display:flex;gap:8px">
      <button class="btn ghost block" onclick="closeModal()">Cancelar</button>
      <button class="btn block" onclick="saveSong('${id||''}')">Salvar</button>
    </div>`);
}
function saveSong(id){
  const l=curLang();
  const o={
    title:document.getElementById('s_title').value.trim(),
    artist:document.getElementById('s_artist').value.trim(),
    youtube:document.getElementById('s_yt').value.trim(),
    start:parseInt(document.getElementById('s_start').value)||0,
    end:parseInt(document.getElementById('s_end').value)||0,
    lyrics:document.getElementById('s_lyrics').value
  };
  if(!o.title){toast('Dê um título à música');return}
  if(id){const s=l.songs.find(x=>x.id===id);Object.assign(s,o);s.transLines=null;}
  else l.songs.push(song(o));
  save();closeModal();renderMusic();toast('Música salva');
}
function delSong(id){const l=curLang();l.songs=l.songs.filter(s=>s.id!==id);save();renderMusic();toast('Música removida')}

/* ---- chamada genérica ao Claude ---- */
async function callClaude(system,messages){
  const res=await fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",headers:{"Content-Type":"application/json"},
    body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,system,messages})
  });
  return await res.json();
}
function extractText(data){return (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('\n')}

/* =========================================================
   Helpers de UI
   ========================================================= */
function section(title,l){
  return `<div class="section-h">
    <div><div class="eyebrow">${l.flag} ${esc(l.name)}</div><h2>${title}</h2></div>
  </div>`;
}
function emptyBox(icon,title,desc,action,btn){
  return `<div class="card pad empty"><div class="big">${icon}</div>
    <h3 style="color:var(--petrol)">${title}</h3>
    <p class="muted" style="margin:8px 0 16px">${desc}</p>
    <button class="btn gold" onclick="${action}">${btn}</button></div>`;
}
function esc(s){return (s==null?'':String(s)).replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
let toastTimer=null;
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2200);}

/* go */
boot();
</script>
