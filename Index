function jpToggleHTML(){return ''}

function startCardSession(all){
  const l=curLang();const t=nowDays();
  session.queue = all ? [...l.vocab] : l.vocab.filter(c=>c.due<=t);
  session.queue.sort(()=>Math.random()-0.5);
  session.done=0;session.total=session.queue.length;
  if(!document.getElementById('cardStage')){
    document.getElementById('view-cards').innerHTML=section('Flashcards',l)+`<div id="cardStage"></div>`;
  }
  nextCard();
}

function nextCard(){
  const stage=document.getElementById('cardStage');
  if(!stage)return;
  if(session.queue.length===0){
    stage.innerHTML=`<div class="card pad empty">
      <div class="big">🎉</div>
      <h3 style="color:var(--petrol)">Sessão concluída!</h3>
      <p class="muted" style="margin:8px 0 16px">Você revisou ${session.total} card(s). Excelente trabalho.</p>
      <button class="btn gold" onclick="go('home')">Voltar ao início</button>
    </div>`;
    return;
  }
  session.card=session.queue[0];
  const pct=Math.round((session.done/session.total)*100);
  stage.innerHTML=`
    <div style="height:6px;background:#e7e2d6;border-radius:99px;margin-bottom:18px;overflow:hidden">
      <div style="height:100%;width:${pct}%;background:var(--gold);transition:.3s"></div>
    </div>
    <div class="flash-wrap">
      <div class="flashcard" id="fc" onclick="flipCard()">
        <div class="flash-inner">
          <div class="flash-face flash-front">
            <span class="tag">Toque para ver</span>
            <div class="word">${dispWord(session.card)}</div>
          </div>
          <div class="flash-face flash-back">
            <span class="tag">Tradução</span>
            <div class="word">${esc(session.card.back)}</div>
            ${session.card.example?`<div class="ex">"${esc(session.card.example)}"</div>`:''}
          </div>
        </div>
      </div>
      <div class="flash-hint" id="fcHint">${session.done} de ${session.total} • toque no card</div>
      <div class="rate-row hidden" id="rateRow">
        <button class="r-again" onclick="rateCard(0)">Errei</button>
        <button class="r-hard" onclick="rateCard(1)">Difícil</button>
        <button class="r-good" onclick="rateCard(2)">Bom</button>
        <button class="r-easy" onclick="rateCard(3)">Fácil</button>
      </div>
    </div>`;
}
function flipCard(){
  const fc=document.getElementById('fc');
  if(fc.classList.contains('flipped'))return;
  fc.classList.add('flipped');
  document.getElementById('rateRow').classList.remove('hidden');
  document.getElementById('fcHint').textContent='Como foi lembrar?';
}
/* SM-2 simplificado */
function rateCard(q){
  const c=session.card;
  if(q===0){ // errei
    c.reps=0;c.interval=0;c.ease=Math.max(1.3,c.ease-0.2);
    session.queue.push(c); // revê de novo na sessão
  }else{
    const quality=[null,3,4,5][q]; // hard/good/easy -> 3/4/5
    c.ease=Math.max(1.3,c.ease+(0.1-(5-quality)*(0.08+(5-quality)*0.02)));
    c.reps++;
    if(c.reps===1)c.interval=1;
    else if(c.reps===2)c.interval=q===1?2:6;
    else c.interval=Math.round(c.interval*c.ease);
    c.due=nowDays()+c.interval;
  }
  session.queue.shift();
  if(q!==0)session.done++;
  logActivity('cards',1);
  save();
  nextCard();
}

