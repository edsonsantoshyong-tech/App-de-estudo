      <button class="btn gold" onclick="renderGrammar()">Refazer</button>
    </div>`;return;
  }
  const q=s.list[s.i];s.answered=false;
  const pct=Math.round((s.i/s.list.length)*100);
  stage.innerHTML=`
    <div style="height:6px;background:#e7e2d6;border-radius:99px;margin-bottom:18px;overflow:hidden">
      <div style="height:100%;width:${pct}%;background:var(--gold);transition:.3s"></div>
    </div>
    <div class="card pad">
      <div class="eyebrow">Questão ${s.i+1} de ${s.list.length}</div>
      <h3 style="font-size:1.2rem;margin:8px 0 16px">${esc(jpText(q.prompt))}</h3>
      <div id="opts">${q.options.map((o,idx)=>`<button class="opt" onclick="answer(${idx})">${esc(jpText(o))}</button>`).join('')}</div>
      <div id="explain"></div>
    </div>`;
}
function answer(idx){
  const s=session.qz;if(s.answered)return;s.answered=true;
  const q=s.list[s.i];
  const opts=document.querySelectorAll('#opts .opt');
  opts.forEach((b,i)=>{b.disabled=true;
    if(i===q.answer)b.classList.add('correct');
    else if(i===idx)b.classList.add('wrong');});
  if(idx===q.answer)s.score++;
  logActivity('quiz',1);
  document.getElementById('explain').innerHTML=`
    <div style="margin-top:14px;padding:12px 14px;border-radius:12px;background:#f4f1e8">
      <strong style="color:${idx===q.answer?'var(--ok)':'var(--warn)'}">${idx===q.answer?'Correto! ✓':'Resposta: '+esc(jpText(q.options[q.answer]))}</strong>
      ${q.explanation?`<p class="muted" style="margin-top:6px;font-size:.9rem">${esc(jpText(q.explanation))}</p>`:''}
    </div>
    <button class="btn block" style="margin-top:14px" onclick="session.qz.i++;renderQuestion()">
      ${s.i+1>=s.list.length?'Ver resultado':'Próxima'}</button>`;
}

