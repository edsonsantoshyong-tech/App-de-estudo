          <div style="font-weight:600">${(COUNTRIES.find(c=>c.k===s.country)||{}).n||s.country} • ${esc(provLine)}</div>
          <div class="muted" style="font-size:.78rem">Idioma: ${l.flag} ${esc(l.name)}${code?` (${code})`:' — defina o código ISO em Gerenciar'}</div>
