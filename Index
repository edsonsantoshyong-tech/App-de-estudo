<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NIPI Línguas — Sistema de Estudo de Idiomas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root{
    --petrol:#0E3A45;
    --petrol-2:#134E5E;
    --petrol-soft:#1c6175;
    --gold:#C9A227;
    --gold-soft:#E2C766;
    --bg:#F6F4EE;
    --surface:#FFFFFF;
    --ink:#15282D;
    --ink-soft:#46595e;
    --line:#E4E0D6;
    --ok:#2E7D5B;
    --warn:#C0563A;
    --radius:16px;
    --shadow:0 6px 24px rgba(14,58,69,.08);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:'DM Sans',system-ui,sans-serif;
    background:var(--bg);
    color:var(--ink);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,.serif{font-family:'DM Serif Display',Georgia,serif;font-weight:400}
  button{font-family:inherit;cursor:pointer;border:none;background:none}
  input,select,textarea{font-family:inherit;font-size:1rem}
  .hidden{display:none!important}

  /* ===== App shell ===== */
  .app{display:flex;flex-direction:column;min-height:100vh}
  header.topbar{
    background:linear-gradient(135deg,var(--petrol),var(--petrol-2));
    color:#fff;padding:14px 18px;display:flex;align-items:center;gap:12px;
    position:sticky;top:0;z-index:30;box-shadow:0 2px 14px rgba(0,0,0,.12)
  }
  .brand{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
  .brand .mark{
    width:34px;height:34px;border-radius:9px;flex:none;
    background:radial-gradient(circle at 30% 30%,var(--gold-soft),var(--gold));
    display:grid;place-items:center;color:var(--petrol);font-family:'DM Serif Display',serif;font-size:18px
  }
  .brand .title{font-family:'DM Serif Display',serif;font-size:1.15rem;line-height:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .brand .sub{font-size:.7rem;opacity:.7;letter-spacing:.14em;text-transform:uppercase}
  .lang-pill{
    background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.22);
    color:#fff;border-radius:999px;padding:6px 12px;font-size:.85rem;font-weight:500;
    display:flex;align-items:center;gap:6px
  }
  .lang-pill select{background:transparent;border:none;color:#fff;font-weight:600;outline:none}
  .lang-pill select option{color:var(--ink)}

  main{flex:1;width:100%;max-width:920px;margin:0 auto;padding:20px 16px 110px}

  /* ===== Nav ===== */
  nav.tabs{
    position:fixed;bottom:0;left:0;right:0;z-index:30;
    background:var(--surface);border-top:1px solid var(--line);
    display:flex;justify-content:space-around;padding:8px 4px env(safe-area-inset-bottom);
    box-shadow:0 -4px 18px rgba(14,58,69,.06)
  }
  nav.tabs button{
    flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;
    padding:6px 2px;color:var(--ink-soft);font-size:.66rem;font-weight:600;border-radius:12px;transition:.15s
  }
  nav.tabs button .ic{font-size:1.2rem;line-height:1}
  nav.tabs button.active{color:var(--petrol)}
  nav.tabs button.active .ic{transform:translateY(-1px)}

  /* ===== Cards / layout ===== */
  .card{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
  .pad{padding:18px}
  .section-h{display:flex;align-items:baseline;justify-content:space-between;margin:4px 2px 14px}
  .section-h h2{font-size:1.5rem}
  .eyebrow{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);font-weight:700}
  .muted{color:var(--ink-soft)}
  .grid{display:grid;gap:14px}
  @media(min-width:620px){.grid.cols2{grid-template-columns:1fr 1fr}.grid.cols3{grid-template-columns:repeat(3,1fr)}}

  /* ===== Buttons ===== */
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:8px;
    background:var(--petrol);color:#fff;border-radius:12px;padding:12px 18px;
    font-weight:600;font-size:.95rem;transition:.15s;border:1px solid transparent
  }
  .btn:hover{background:var(--petrol-2)}
  .btn:active{transform:translateY(1px)}
  .btn.gold{background:var(--gold);color:var(--petrol)}
  .btn.gold:hover{background:var(--gold-soft)}
  .btn.ghost{background:transparent;color:var(--petrol);border-color:var(--line)}
  .btn.ghost:hover{background:#f0ede5}
  .btn.block{width:100%}
  .btn.sm{padding:8px 12px;font-size:.85rem;border-radius:10px}
  .btn:disabled{opacity:.45;cursor:not-allowed}

  /* ===== Forms ===== */
  label.field{display:block;margin-bottom:12px}
  label.field span{display:block;font-size:.8rem;font-weight:600;color:var(--ink-soft);margin-bottom:5px}
  .input{
    width:100%;padding:11px 13px;border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--ink)
  }
  .input:focus{outline:2px solid var(--gold-soft);border-color:var(--gold)}
  textarea.input{resize:vertical;min-height:70px}

  /* ===== Stats / metrics ===== */
  .metric{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:16px}
  .metric .n{font-family:'DM Serif Display',serif;font-size:2rem;color:var(--petrol);line-height:1}
  .metric .l{font-size:.74rem;text-transform:uppercase;letter-spacing:.08em;color:var(--ink-soft);margin-top:6px;font-weight:600}
  .metric .l b{color:var(--gold)}

  /* ===== Flashcard ===== */
  .flash-wrap{display:flex;flex-direction:column;align-items:center;gap:18px}
  .flashcard{
    width:100%;max-width:460px;aspect-ratio:3/2;perspective:1200px;cursor:pointer
  }
  .flash-inner{position:relative;width:100%;height:100%;transition:transform .5s cubic-bezier(.4,.2,.2,1);transform-style:preserve-3d}
  .flashcard.flipped .flash-inner{transform:rotateY(180deg)}
  .flash-face{
    position:absolute;inset:0;backface-visibility:hidden;border-radius:20px;
    display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;
    box-shadow:var(--shadow)
  }
  .flash-front{background:linear-gradient(135deg,var(--petrol),var(--petrol-2));color:#fff}
  .flash-back{background:var(--surface);border:1px solid var(--line);color:var(--ink);transform:rotateY(180deg)}
  .flash-face .word{font-family:'DM Serif Display',serif;font-size:2rem;line-height:1.15}
  .flash-face .ex{margin-top:14px;font-size:.92rem;font-style:italic;opacity:.85;max-width:90%}
  .flash-face .tag{position:absolute;top:14px;left:16px;font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;opacity:.7;font-weight:700}
  .flash-hint{font-size:.8rem;color:var(--ink-soft)}
  .rate-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;width:100%;max-width:460px}
  .rate-row button{padding:12px 4px;border-radius:12px;font-weight:600;font-size:.82rem;color:#fff;border:none}
  .r-again{background:#C0563A}.r-hard{background:#D08A36}.r-good{background:#2E7D5B}.r-easy{background:#1c6175}

  /* ===== Quiz ===== */
  .opt{
    display:block;width:100%;text-align:left;padding:14px 16px;border:1px solid var(--line);
    border-radius:12px;background:#fff;margin-bottom:10px;font-weight:500;transition:.12s
  }
  .opt:hover{border-color:var(--petrol-soft)}
  .opt.correct{background:#e7f4ed;border-color:var(--ok);color:#1c5a40}
  .opt.wrong{background:#fbeae5;border-color:var(--warn);color:#8a3a25}
  .opt:disabled{cursor:default}

  /* ===== Chat ===== */
  .chat-log{display:flex;flex-direction:column;gap:10px;min-height:240px;max-height:46vh;overflow-y:auto;padding:4px}
  .bubble{padding:10px 14px;border-radius:14px;max-width:85%;font-size:.92rem;white-space:pre-wrap;line-height:1.45}
  .bubble.user{align-self:flex-end;background:var(--petrol);color:#fff;border-bottom-right-radius:4px}
  .bubble.ai{align-self:flex-start;background:#fff;border:1px solid var(--line);border-bottom-left-radius:4px}
  .bubble.sys{align-self:center;background:#efe9d8;color:var(--ink-soft);font-size:.8rem;border-radius:999px;padding:6px 14px}
  .chat-input{display:flex;gap:8px;margin-top:12px}
  .typing{display:inline-flex;gap:4px}.typing i{width:7px;height:7px;border-radius:50%;background:var(--petrol-soft);animation:bl 1s infinite}
  .typing i:nth-child(2){animation-delay:.15s}.typing i:nth-child(3){animation-delay:.3s}
  @keyframes bl{0%,60%,100%{opacity:.3}30%{opacity:1}}

  /* ===== Lists / editor ===== */
  .row-item{display:flex;align-items:center;gap:10px;padding:12px;border:1px solid var(--line);border-radius:12px;background:#fff;margin-bottom:8px}
  .row-item .grow{flex:1;min-width:0}
  .row-item .grow .t{font-weight:600}
  .row-item .grow .d{font-size:.84rem;color:var(--ink-soft)}
  .icon-btn{width:34px;height:34px;border-radius:9px;display:grid;place-items:center;font-size:1rem;border:1px solid var(--line);background:#fff;color:var(--ink-soft)}
  .icon-btn:hover{background:#f0ede5}
  .seg{display:flex;background:#efe9d8;border-radius:12px;padding:4px;gap:4px;margin-bottom:16px}
  .seg button{flex:1;padding:9px;border-radius:9px;font-weight:600;font-size:.85rem;color:var(--ink-soft)}
  .seg button.active{background:#fff;color:var(--petrol);box-shadow:0 1px 4px rgba(0,0,0,.08)}
  .empty{text-align:center;padding:34px 18px;color:var(--ink-soft)}
  .empty .big{font-size:2.4rem;margin-bottom:8px}

  /* ===== Onboarding ===== */
  .onb{min-height:100vh;display:grid;place-items:center;padding:24px;background:linear-gradient(160deg,var(--petrol),var(--petrol-2))}
  .onb .box{background:var(--surface);border-radius:22px;padding:30px 26px;max-width:420px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.3)}
  .onb h1{font-size:1.9rem;color:var(--petrol);margin-bottom:4px}
  .onb .mk{width:54px;height:54px;border-radius:14px;background:radial-gradient(circle at 30% 30%,var(--gold-soft),var(--gold));display:grid;place-items:center;font-family:'DM Serif Display',serif;font-size:28px;color:var(--petrol);margin-bottom:16px}

  /* ===== Modal ===== */
  .modal-bg{position:fixed;inset:0;background:rgba(14,40,45,.55);z-index:60;display:grid;place-items:center;padding:18px}
  .modal{background:#fff;border-radius:18px;width:100%;max-width:440px;max-height:88vh;overflow-y:auto;padding:22px}
  .modal h3{font-size:1.3rem;color:var(--petrol);margin-bottom:14px}
  .toast{position:fixed;bottom:84px;left:50%;transform:translateX(-50%);background:var(--petrol);color:#fff;padding:10px 18px;border-radius:999px;font-size:.88rem;z-index:80;box-shadow:var(--shadow);opacity:0;transition:.25s;pointer-events:none}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(-6px)}
  .badge{font-size:.66rem;font-weight:700;padding:3px 8px;border-radius:999px;background:#efe9d8;color:var(--petrol-2)}
  .due-dot{background:var(--gold);color:var(--petrol)}
</style>
</head>
<body>

<!-- ONBOARDING -->
<div id="onboarding" class="onb hidden">
  <div class="box">
    <div class="mk">N</div>
    <h1>NIPI Línguas</h1>
    <p class="muted" style="margin-bottom:20px">Seu sistema integrado de estudo de idiomas. Vamos começar criando seu perfil.</p>
    <label class="field"><span>Como podemos te chamar?</span>
      <input id="onbName" class="input" placeholder="Seu nome" maxlength="40"></label>
    <label class="field"><span>Qual idioma você quer estudar primeiro?</span>
      <select id="onbLang" class="input"></select></label>
    <button class="btn gold block" onclick="finishOnboarding()">Começar a estudar</button>
  </div>
</div>

<!-- APP -->
<div id="app" class="app hidden">
  <header class="topbar">
    <div class="brand">
      <div class="mark">N</div>
      <div style="min-width:0">
        <div class="title">NIPI Línguas</div>
        <div class="sub">Estudo integrado</div>
      </div>
    </div>
    <div class="lang-pill">
      <span>🌐</span>
      <select id="langSwitch" onchange="switchLang(this.value)"></select>
    </div>
  </header>

  <main>
    <!-- INÍCIO -->
    <section id="view-home"></section>
    <!-- FLASHCARDS -->
    <section id="view-cards" class="hidden"></section>
    <!-- GRAMÁTICA -->
    <section id="view-grammar" class="hidden"></section>
    <!-- CONVERSA -->
    <section id="view-chat" class="hidden"></section>
    <!-- MÚSICA -->
    <section id="view-music" class="hidden"></section>
    <!-- GERENCIAR -->
    <section id="view-manage" class="hidden"></section>
  </main>

  <nav class="tabs">
    <button data-view="home" class="active" onclick="go('home')"><span class="ic">🏠</span>Início</button>
    <button data-view="cards" onclick="go('cards')"><span class="ic">🃏</span>Flashcards</button>
    <button data-view="grammar" onclick="go('grammar')"><span class="ic">✏️</span>Gramática</button>
    <button data-view="chat" onclick="go('chat')"><span class="ic">💬</span>Conversa</button>
    <button data-view="music" onclick="go('music')"><span class="ic">🎵</span>Música</button>
    <button data-view="manage" onclick="go('manage')"><span class="ic">⚙️</span>Gerenciar</button>
  </nav>
</div>

<div id="toast" class="toast"></div>
<div id="modalHost"></div>

<script>
/* =========================================================
   NIPI Línguas — núcleo de dados
   ========================================================= */
const STORE_KEY = 'nipi_linguas_v1';
const FLAGS = ['🇬🇧','🇪🇸','🇫🇷','🇮🇹','🇩🇪','🇧🇷','🇵🇹','🇯🇵','🇨🇳','🇷🇺','🌐'];

let DB = null;       // estado global
let session = {};    // estado volátil (flashcard atual, quiz, chat)

function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,7)}
function todayKey(){return new Date().toISOString().slice(0,10)}
function nowDays(){return Math.floor(Date.now()/86400000)}

/* ---- seed inicial ---- */
function seed(){
  return {
    learner:{name:''},
    currentLangId:null,
    languages:[
      lang('Inglês','🇬🇧',[
        vcard('the house','a casa','I live in the house.'),
        vcard('to learn','aprender','I want to learn English.'),
        vcard('every day','todos os dias','I study every day.'),
        vcard('the book','o livro','She reads a book.'),
        vcard('beautiful','bonito(a)','What a beautiful day!'),
      ],[
        gq('Choose the correct form: "She ___ to school."',['go','goes','going'],1,'Com he/she/it usamos o verbo + s no presente simples.'),
        gq('Plural of "child":',['childs','childes','children'],2,'"Children" é um plural irregular.'),
        gq('"I ___ coffee every morning."',['drink','drinks','am drink'],0,'Com "I" usamos a forma base do verbo.'),
      ],[
        song({title:'Exemplo: cole sua música aqui',artist:'Toque para abrir e editar',youtube:'',start:0,end:0,
          lyrics:"Edite esta música e cole a letra de uma canção que você gosta.\nAdicione o link do YouTube e escolha um trecho (início e fim em segundos).\nDepois use \"Traduzir letra\" e \"Gerar flashcards\"."})
      ]),
      lang('Espanhol','🇪🇸',[
        vcard('la casa','a casa','Vivo en la casa.'),
        vcard('aprender','aprender','Quiero aprender español.'),
        vcard('todos los días','todos os dias','Estudio todos los días.'),
        vcard('el libro','o livro','Ella lee un libro.'),
      ],[
        gq('"Yo ___ español." (hablar)',['hablo','hablas','habla'],0,'Primeira pessoa do singular: hablo.'),
        gq('Artigo correto: "___ mesa"',['el','la','los'],1,'"Mesa" é feminino: la mesa.'),
      ]),
    ],
    stats:{log:{}} // {data:{cards:n, quiz:n}}
  };
}
function lang(name,flag,vocab,grammar,songs){return {id:uid(),name,flag,vocab,grammar,songs:songs||[]}}
function song(o){return {id:uid(),title:o.title,artist:o.artist||'',youtube:o.youtube||'',start:o.start||0,end:o.end||0,lyrics:o.lyrics||'',transLines:null}}
function vcard(front,back,example){return {id:uid(),front,back,example:example||'',ease:2.5,interval:0,reps:0,due:0}}
function gq(prompt,options,answer,explanation){return {id:uid(),prompt,options,answer,explanation:explanation||''}}

/* ---- persistência ---- */
function save(){try{localStorage.setItem(STORE_KEY,JSON.stringify(DB))}catch(e){console.warn(e)}}
function load(){
  try{const raw=localStorage.getItem(STORE_KEY);if(raw)return JSON.parse(raw)}catch(e){}
  return null;
}
function curLang(){return DB.languages.find(l=>l.id===DB.currentLangId)||DB.languages[0]}

function logActivity(type,n){
  const k=todayKey();
  if(!DB.stats.log[k])DB.stats.log[k]={cards:0,quiz:0};
  DB.stats.log[k][type]=(DB.stats.log[k][type]||0)+n;
  save();
}

/* =========================================================
   Inicialização
   ========================================================= */
function boot(){
  DB = load();
  if(DB&&DB.languages){DB.languages.forEach(l=>{if(!l.songs)l.songs=[]});}
  if(!DB || !DB.languages || !DB.learner.name){
    DB = DB || seed();
    showOnboarding();
  }else{
    if(!DB.currentLangId)DB.currentLangId=DB.languages[0]?.id;
    startApp();
  }
}

function showOnboarding(){
  const tmp = DB && DB.languages ? DB : seed();
  document.getElementById('onboarding').classList.remove('hidden');
  document.getElementById('app').classList.add('hidden');
  const sel=document.getElementById('onbLang');
  sel.innerHTML = tmp.languages.map(l=>`<option value="${l.id}">${l.flag} ${l.name}</option>`).join('');
  window.__tmpDB = tmp;
}
function finishOnboarding(){
  const name=document.getElementById('onbName').value.trim();
  if(!name){toast('Digite seu nome para continuar');return}
  DB = window.__tmpDB || seed();
  DB.learner.name=name;
  DB.currentLangId=document.getElementById('onbLang').value;
  save();
  document.getElementById('onboarding').classList.add('hidden');
  startApp();
}

function startApp(){
  document.getElementById('app').classList.remove('hidden');
  refreshLangSwitch();
  go('home');
}

function refreshLangSwitch(){
  const sel=document.getElementById('langSwitch');
  sel.innerHTML=DB.languages.map(l=>`<option value="${l.id}" ${l.id===DB.currentLangId?'selected':''}>${l.flag} ${l.name}</option>`).join('');
}
function switchLang(id){DB.currentLangId=id;save();go(currentView)}

/* =========================================================
   Navegação
   ========================================================= */
let currentView='home';
function go(view){
  currentView=view;
  ['home','cards','grammar','chat','music','manage'].forEach(v=>{
    document.getElementById('view-'+v).classList.toggle('hidden',v!==view);
  });
  document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.toggle('active',b.dataset.view===view));
  if(view==='home')renderHome();
  if(view==='cards')renderCards();
  if(view==='grammar')renderGrammar();
  if(view==='chat')renderChat();
  if(view==='music')renderMusic();
  if(view==='manage')renderManage();
  window.scrollTo(0,0);
}

/* =========================================================
   INÍCIO
   ========================================================= */
function dueCount(l){const t=nowDays();return l.vocab.filter(c=>c.due<=t).length}
function streak(){
  let s=0;const d=new Date();
  for(;;){const k=d.toISOString().slice(0,10);const e=DB.stats.log[k];
    if(e&&((e.cards||0)+(e.quiz||0))>0){s++;d.setDate(d.getDate()-1)}else break}
  return s;
}
function todayTotal(){const e=DB.stats.log[todayKey()];return e?((e.cards||0)+(e.quiz||0)):0}

function renderHome(){
  const l=curLang();const due=dueCount(l);
  const el=document.getElementById('view-home');
  el.innerHTML=`
    <div class="section-h">
      <div>
        <div class="eyebrow">Olá, ${esc(DB.learner.name)}</div>
        <h2>Bom estudo!</h2>
      </div>
    </div>
    <div class="grid cols3" style="margin-bottom:16px">
      <div class="metric"><div class="n">${streak()}</div><div class="l">Dias seguidos 🔥</div></div>
      <div class="metric"><div class="n">${todayTotal()}</div><div class="l">Estudos hoje</div></div>
      <div class="metric"><div class="n">${due}</div><div class="l"><b>Cards</b> para revisar</div></div>
    </div>

    <div class="card pad" style="margin-bottom:14px">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
        <div style="font-size:2rem">${l.flag}</div>
        <div><div class="eyebrow">Idioma atual</div><h3 style="font-size:1.3rem">${esc(l.name)}</h3></div>
      </div>
      <div class="grid cols2">
        <button class="btn block ${due?'gold':''}" onclick="go('cards')">
          🃏 Revisar flashcards ${due?`<span class="badge due-dot">${due}</span>`:''}
        </button>
        <button class="btn ghost block" onclick="go('grammar')">✏️ Gramática (${l.grammar.length})</button>
        <button class="btn ghost block" onclick="go('chat')">💬 Conversar com IA</button>
        <button class="btn ghost block" onclick="go('music')">🎵 Estudar com música (${l.songs?l.songs.length:0})</button>
        <button class="btn ghost block" onclick="go('manage')">⚙️ Gerenciar conteúdo</button>
      </div>
    </div>

    <div class="card pad">
