let weekChartRef=null;
function drawWeekChart(){
  const labels=[],cards=[],quiz=[];
  for(let i=6;i>=0;i--){
    const d=new Date();d.setDate(d.getDate()-i);
    const k=d.toISOString().slice(0,10);
    labels.push(d.toLocaleDateString('pt-BR',{weekday:'short'}).replace('.',''));
    const e=DB.stats.log[k]||{};
    cards.push(e.cards||0);quiz.push(e.quiz||0);
  }
  const ctx=document.getElementById('weekChart');if(!ctx)return;
  if(weekChartRef)weekChartRef.destroy();
  weekChartRef=new Chart(ctx,{
    type:'bar',
    data:{labels,datasets:[
      {label:'Flashcards',data:cards,backgroundColor:'#134E5E',borderRadius:6,stack:'a'},
      {label:'Gramática',data:quiz,backgroundColor:'#C9A227',borderRadius:6,stack:'a'}
    ]},
    options:{responsive:true,plugins:{legend:{position:'bottom',labels:{font:{family:'DM Sans'},boxWidth:12}}},
      scales:{x:{grid:{display:false}},y:{beginAtZero:true,ticks:{precision:0},grid:{color:'#eee'}}}}
  });
}

