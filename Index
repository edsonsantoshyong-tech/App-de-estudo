function backfillReadings(){
  const ja=CURRICULUM.ja;if(!ja)return;
  const map={};ja.levels.forEach(lv=>lv.core.forEach(it=>{if(it.r)map[normWord(it.f)]=it.r}));
  let changed=false;
  DB.languages.forEach(l=>{
    if(!isJapaneseLang(l))return;
    l.vocab.forEach(c=>{
      if(!c.reading){const base=normWord(splitJp(c.front).base);if(map[base]){c.reading=map[base];changed=true;}}
    });
  });
  if(changed)save();
}

