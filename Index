function recoCards(list){
  if(!list.length)return '<p class="empty muted">Nenhum título encontrado para esses filtros.</p>';
  return list.map((r,i)=>`<div class="row-item" style="cursor:pointer" onclick="recoStudy(${i})">
    ${r.poster?`<img src="${esc(r.poster)}" style="width:42px;height:62px;object-fit:cover;border-radius:6px;flex:none" onerror="this.style.display='none'">`:'<div style="font-size:1.4rem">🎬</div>'}
    <div class="grow"><div class="t">${esc(r.title)}${r.year?` <span class="muted">(${r.year})</span>`:''}</div>
      <div class="d">${(r.providers||[]).map(esc).join(' • ')||'—'}</div></div>
    <span class="badge">estudar</span>
  </div>`).join('');
}
async function fetchReco(){
  const l=curLang();const s=DB.settings;const code=langCode(l);
  if(!s.catalogEndpoint){toast('Conecte o catálogo em Gerenciar › Dados');return}
  if(!s.providers.length){toast('Selecione ao menos um provedor');return}
  const box=document.getElementById('recoResults');
  box.innerHTML=`<div style="text-align:center;padding:24px"><span class="typing"><i></i><i></i><i></i></span><p class="muted" style="margin-top:10px">Buscando no catálogo…</p></div>`;
  try{
    const res=await fetch(s.catalogEndpoint,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({language:code,country:s.country,providers:s.providers,page:1})});
    const data=await res.json();
    const list=(data.results||[]).map(r=>({
      title:r.title||r.name||'',year:r.year||(r.release_date||'').slice(0,4),
      poster:r.poster||'',providers:r.providers||[]
    })).filter(r=>r.title);
    session.reco=list;box.innerHTML=recoCards(list);
  }catch(e){
    box.innerHTML=`<div class="card pad"><p class="muted">Não foi possível buscar agora. Verifique o endpoint do catálogo em Gerenciar › Dados. (No GitHub Pages, é necessário o backend conectado.)</p></div>`;
  }
}
function recoStudy(i){
  const r=(session.reco||[])[i];if(!r)return;
  generateFilmCore(r.title,'name','','');
}

