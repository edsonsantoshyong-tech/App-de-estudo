function renderQuestion(){
  const s=session.qz;const stage=document.getElementById('quizStage');
  if(s.i>=s.list.length){
    stage.innerHTML=`<div class="card pad empty">
      <div class="big">${s.score===s.list.length?'🏆':'📘'}</div>
      <h3 style="color:var(--petrol)">Você acertou ${s.score} de ${s.list.length}</h3>
