function renderChat(){
  const l=curLang();
  const el=document.getElementById('view-chat');
  if(!session.chat)session.chat=[];
  el.innerHTML=section('Conversa',l)+`
    <div class="card pad">
      <div style="display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap">
        <span class="badge">Tutor de ${esc(l.name)}</span>
        <select id="chatLevel" class="input" style="width:auto;padding:6px 10px;font-size:.85rem">
          <option value="iniciante">Iniciante</option>
          <option value="intermediário">Intermediário</option>
          <option value="avançado">Avançado</option>
        </select>
        <button class="btn ghost sm" onclick="resetChat()">Reiniciar</button>
      </div>
      <div class="chat-log" id="chatLog"></div>
      <div class="chat-input">
        <input id="chatInput" class="input" placeholder="Escreva em ${esc(l.name)}..." onkeydown="if(event.key==='Enter')sendChat()">
        <button class="btn" id="chatSend" onclick="sendChat()">➤</button>
      </div>
      <p class="muted" style="font-size:.74rem;margin-top:8px">O tutor corrige seus erros e conversa no seu nível. A IA funciona dentro do app no claude.ai.</p>
    </div>`;
  paintChat();
}
function resetChat(){session.chat=[];paintChat()}
function paintChat(){
  const log=document.getElementById('chatLog');if(!log)return;
  if(session.chat.length===0){
    log.innerHTML=`<div class="bubble sys">Comece a conversar! Escreva uma frase e o tutor responde e corrige.</div>`;
  }else{
    log.innerHTML=session.chat.map(m=>`<div class="bubble ${m.role==='user'?'user':'ai'}">${esc(m.content)}</div>`).join('');
  }
  log.scrollTop=log.scrollHeight;
}
async function sendChat(){
  const input=document.getElementById('chatInput');
  const text=input.value.trim();if(!text)return;
  const l=curLang();
  const level=document.getElementById('chatLevel').value;
  session.chat.push({role:'user',content:text});
  input.value='';paintChat();
  const log=document.getElementById('chatLog');
  const typing=document.createElement('div');
  typing.className='bubble ai';typing.innerHTML='<span class="typing"><i></i><i></i><i></i></span>';
  log.appendChild(typing);log.scrollTop=log.scrollHeight;
  document.getElementById('chatSend').disabled=true;

  const sys=`Você é um tutor amigável de ${l.name} para um falante de português brasileiro de nível ${level}.
Regras:
- Responda principalmente em ${l.name}, de forma simples e adequada ao nível ${level}.
- Se o aluno cometer erros, corrija gentilmente: mostre a forma correta entre parênteses e uma breve explicação em português.
- Faça sempre uma pergunta de acompanhamento para manter a conversa.
- Seja breve (2-4 frases).`;

  try{
    const messages=session.chat.map(m=>({role:m.role,content:m.content}));
    const res=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,system:sys,messages})
    });
    const data=await res.json();
    const reply=(data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('\n').trim()
      || 'Desculpe, não consegui responder agora.';
    session.chat.push({role:'assistant',content:reply});
  }catch(e){
    session.chat.push({role:'assistant',content:'⚠️ Não foi possível conectar ao tutor. A conversa com IA funciona no preview do claude.ai. Em outro servidor (ex.: GitHub Pages), é preciso um backend próprio.'});
  }finally{
    document.getElementById('chatSend').disabled=false;
    paintChat();
  }
}

