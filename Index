function saveQ(id){
  const l=curLang();
  const prompt=document.getElementById('q_prompt').value.trim();
  const opts=[...document.querySelectorAll('.q_opt')].map(i=>i.value.trim()).filter(Boolean);
  const ansEl=document.querySelector('input[name="q_ans"]:checked');
  const exp=document.getElementById('q_exp').value.trim();
  if(!prompt||opts.length<2){toast('Enunciado e ao menos 2 opções');return}
  let answer=ansEl?parseInt(ansEl.value):0;if(answer>=opts.length)answer=0;
  if(id){const q=l.grammar.find(x=>x.id===id);q.prompt=prompt;q.options=opts;q.answer=answer;q.explanation=exp;}
  else l.grammar.push(gq(prompt,opts,answer,exp));
  save();closeModal();renderManage();toast('Questão salva');
