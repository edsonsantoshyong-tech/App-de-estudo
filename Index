/* =========================================================
   TESTE GRAMATICAL a partir de mídia (música/filme)
   ========================================================= */
async function genGrammarFromText(text,label){
  const l=curLang();
  modal(`<h3>Gerando teste…</h3><div style="text-align:center;padding:20px">
    <span class="typing"><i></i><i></i><i></i></span>
    <p class="muted" style="margin-top:12px">Criando questões de gramática em ${esc(l.name)}.</p></div>`);
  const sys=`Crie um teste de gramática de ${l.name} para um falante de português brasileiro, baseado no conteúdo a seguir (${label}).
Gere de 4 a 6 questões de múltipla escolha sobre estruturas gramaticais típicas ou que aparecem no conteúdo.
Cada questão deve ter: enunciado claro, 3 opções, o índice (0 a 2) da opção correta e uma explicação curta em português.
Responda APENAS com um array JSON, sem markdown:
[{"prompt":"","options":["","",""],"answer":0,"explanation":""}]`;
  try{
    const data=await callClaude(sys,[{role:'user',content:(text||'').slice(0,8000)}]);
    let txt=extractText(data).replace(/```json|```/g,'').trim();
    let arr=JSON.parse(txt);
    if(!Array.isArray(arr)||!arr.length)throw 0;
    let n=0;
    arr.forEach(q=>{
      if(q.prompt&&Array.isArray(q.options)&&q.options.length>=2&&typeof q.answer==='number'){
        const ans=Math.max(0,Math.min(q.options.length-1,q.answer));
        l.grammar.push(gq(q.prompt,q.options,ans,q.explanation||''));n++;
      }
    });
    save();closeModal();toast(n+' questões adicionadas à Gramática');
  }catch(e){
    modal(`<h3>Ops</h3><p class="muted" style="margin-bottom:16px">Não consegui gerar o teste agora. A IA funciona no preview do claude.ai ou com seu backend conectado.</p>
      <button class="btn block" onclick="closeModal()">Fechar</button>`);
  }
}
function genGrammarForSong(id){const l=curLang();const s=l.songs.find(x=>x.id===id);if(!s||!s.lyrics.trim()){toast('Cole a letra primeiro');return}genGrammarFromText(s.lyrics,'letra da música "'+s.title+'"');}
function genGrammarForFilm(id){const l=curLang();const f=l.films.find(x=>x.id===id);if(!f)return;const ctx=f.title+'\n'+f.words.map(w=>`${w.front} = ${w.back}`).join('\n');genGrammarFromText(ctx,'filme/série "'+f.title+'"');}

/* ---- chamada genérica ao Claude ---- */
async function callClaude(system,messages){
  const url=(DB.settings&&DB.settings.aiEndpoint)?DB.settings.aiEndpoint:"https://api.anthropic.com/v1/messages";
  const res=await fetch(url,{
    method:"POST",headers:{"Content-Type":"application/json"},
    body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,system,messages})
  });
  return await res.json();
}
function extractText(data){return (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('\n')}

/* =========================================================
   NÍVEL — trilha e teste de nivelamento (local, sem IA)
   ========================================================= */
function deckCardFor(l,item){return l.vocab.find(c=>normWord(splitJp(c.front).base)===normWord(item.f))}
function levelItemStatus(l,item){const c=deckCardFor(l,item);if(!c)return 'nova';return cardMastered(c)?'sei':'aprendendo'}
function levelProgress(l,lv){const m=lv.core.filter(it=>levelItemStatus(l,it)==='sei').length;return {mastered:m,total:lv.core.length,pct:Math.round(m/(lv.core.length||1)*100)}}
function dispItem(item){return langKey(curLang())==='ja'?jpRender(item.f,item.r):esc(item.f)}

function openLevel(id){DB.currentLangId=id;save();refreshLangSwitch();go('level')}

function renderLevel(){
  const l=curLang();const curr=curCurriculum();
  const el=document.getElementById('view-level');
  if(!curr){
    el.innerHTML=`<div class="section-h"><div><div class="eyebrow">${l.flag} ${esc(l.name)}</div><h2>Nível</h2></div>
      <button class="btn ghost sm" onclick="go('home')">‹ Voltar</button></div>
      <div class="card pad empty"><div class="big">🏷️</div><h3 style="color:var(--petrol)">Sem trilha de níveis</h3>
      <p class="muted" style="margin:8px 0 0">O sistema de níveis está disponível para Inglês, Espanhol, Japonês e Coreano. Defina o código ISO do idioma em Gerenciar para habilitar.</p></div>`;
    return;
  }
  if(!l.level){
    el.innerHTML=`<div class="section-h"><div><div class="eyebrow">${l.flag} ${esc(l.name)} • ${curr.framework}</div><h2>Descubra seu nível</h2></div>
      <button class="btn ghost sm" onclick="go('home')">‹ Voltar</button></div>
      <div class="card pad empty"><div class="big">🎯</div>
        <h3 style="color:var(--petrol)">Teste de nivelamento</h3>
        <p class="muted" style="margin:8px 0 16px">Um teste rápido (${curr.levels.length*2} questões) pra te posicionar de ${curr.levels[0].label} a ${curr.levels[curr.levels.length-1].label}. Roda offline, sem IA.</p>
        <button class="btn gold" onclick="startPlacement()">Começar teste</button></div>`;
    return;
  }
  const idx=curr.levels.findIndex(x=>x.id===l.level);
  const lv=curr.levels[idx];const next=curr.levels[idx+1];
  const pr=levelProgress(l,lv);
  el.innerHTML=`
    <div class="section-h"><div><div class="eyebrow">${l.flag} ${esc(l.name)} • ${curr.framework}</div><h2>Seu nível: ${lv.label}</h2></div>
      <button class="btn ghost sm" onclick="go('home')">‹ Voltar</button></div>
    <div class="card pad" style="margin-bottom:14px">
      <p class="muted" style="margin-bottom:12px">${esc(lv.desc)}</p>
      <div style="display:flex;justify-content:space-between;font-size:.82rem;font-weight:600;margin-bottom:6px">
        <span>Domínio do nível ${lv.label}</span><span>${pr.mastered}/${pr.total}</span></div>
      <div style="height:10px;background:#e7e2d6;border-radius:99px;overflow:hidden;margin-bottom:10px">
        <div style="height:100%;width:${pr.pct}%;background:linear-gradient(90deg,var(--gold),var(--gold-soft));transition:.4s"></div></div>
      <p class="muted" style="font-size:.84rem">${next?(pr.pct>=80?`Você está pronto para ${next.label}! 🎉`:`Domine os itens-chave para avançar ao ${next.label}.`):'Você está no nível máximo. 🏆'}</p>
    </div>

    <div class="card pad" style="margin-bottom:14px">
      <div class="eyebrow">Gramática-chave</div>
      <p style="margin:6px 0 14px">${lv.grammar.map(g=>`<span class="badge" style="margin:2px 4px 2px 0">${esc(g)}</span>`).join('')}</p>
      <div class="eyebrow">Vocabulário essencial</div>
      <div style="margin-top:8px">
        ${lv.core.map(it=>{const s=levelItemStatus(l,it);const chip=s==='sei'?'<span class="badge" style="background:#e7f4ed;color:#1c5a40">domino</span>':s==='aprendendo'?'<span class="badge" style="background:#fbf0d8;color:#8a6a16">estudando</span>':'<span class="badge" style="background:#fbeae5;color:#8a3a25">nova</span>';
          return `<div class="row-item"><div class="grow"><div class="t">${dispItem(it)}</div><div class="d">${esc(it.b)}</div></div>${chip}</div>`}).join('')}
      </div>
      <button class="btn gold block" style="margin-top:12px" onclick="addLevelToDeck('${lv.id}')">+ Adicionar itens deste nível ao baralho</button>
    </div>

    ${next?`<div class="card pad" style="margin-bottom:14px">
      <div class="eyebrow">Próximo nível</div>
      <h3 style="font-size:1.15rem;margin:4px 0 6px">${next.label}</h3>
      <p class="muted" style="font-size:.86rem">${esc(next.desc)}</p>
    </div>`:''}
    <button class="btn ghost block" onclick="if(confirm('Refazer o teste de nivelamento?')){curLang().level=null;save();renderLevel()}">Refazer teste de nivelamento</button>`;
}

function addLevelToDeck(levelId){
  const l=curLang();const curr=curCurriculum();const lv=levelById(curr,levelId);
  let n=0;
  lv.core.forEach(it=>{if(!deckCardFor(l,it)){l.vocab.push(vcard(it.f,it.b,'',it.r||''));n++}});
  save();renderLevel();refreshLangSwitch();
  toast(n?`${n} itens adicionados ao baralho`:'Todos já estão no baralho');
}

/* ---- teste de nivelamento ---- */
function startPlacement(){
  const curr=curCurriculum();if(!curr)return;
  const allBacks=[];curr.levels.forEach(lv=>lv.core.forEach(it=>allBacks.push(it.b)));
  const qs=[];
  curr.levels.forEach(lv=>{
    [...lv.core].sort(()=>Math.random()-0.5).slice(0,2).forEach(it=>{
      const opts=[it.b];let g=0;
      while(opts.length<4&&g<80){g++;const cand=allBacks[Math.floor(Math.random()*allBacks.length)];if(!opts.includes(cand))opts.push(cand)}
      opts.sort(()=>Math.random()-0.5);
      qs.push({levelId:lv.id,word:it,options:opts,answer:opts.indexOf(it.b)});
    });
  });
  session.place={qs,i:0,perLevel:{}};
  renderPlacement();
}
function renderPlacement(){
  const p=session.place;const el=document.getElementById('view-level');
  if(p.i>=p.qs.length){finishPlacement();return}
  const q=p.qs[p.i];const pct=Math.round(p.i/p.qs.length*100);
  el.innerHTML=`
    <div class="section-h"><div><div class="eyebrow">Teste de nivelamento</div><h2 style="font-size:1.3rem">Questão ${p.i+1} de ${p.qs.length}</h2></div></div>
    <div style="height:6px;background:#e7e2d6;border-radius:99px;margin-bottom:18px;overflow:hidden"><div style="height:100%;width:${pct}%;background:var(--gold)"></div></div>
    <div class="card pad">
      <p class="muted" style="font-size:.84rem">O que significa:</p>
      <h3 style="font-size:1.6rem;margin:6px 0 16px">${langKey(curLang())==='ja'?`${esc(q.word.f)}${q.word.r?` <span class="muted" style="font-size:.6em">(${esc(q.word.r)})</span>`:''}`:esc(q.word.f)}</h3>
      ${q.options.map((o,i)=>`<button class="opt" onclick="placeAnswer(${i})">${esc(o)}</button>`).join('')}
      <button class="btn ghost block sm" style="margin-top:6px" onclick="placeAnswer(-1)">Não sei</button>
    </div>`;
}
function placeAnswer(idx){
  const p=session.place;const q=p.qs[p.i];
  if(!p.perLevel[q.levelId])p.perLevel[q.levelId]={c:0,t:0};
  p.perLevel[q.levelId].t++;
  if(idx===q.answer)p.perLevel[q.levelId].c++;
  p.i++;
  renderPlacement();
}
function finishPlacement(){
  const curr=curCurriculum();const p=session.place;const l=curLang();
  let assigned=curr.levels[0].id;
  for(const lv of curr.levels){
    const s=p.perLevel[lv.id]||{c:0,t:1};
    if((s.c/s.t)>=0.6)assigned=lv.id;else break;
  }
  l.level=assigned;save();refreshLangSwitch();
  const lv=levelById(curr,assigned);
  const el=document.getElementById('view-level');
  el.innerHTML=`<div class="card pad empty" style="margin-top:20px">
    <div class="big">🎯</div>
    <div class="eyebrow">Seu nível em ${esc(l.name)}</div>
    <div style="font-family:'DM Serif Display',serif;font-size:3rem;color:var(--petrol);line-height:1;margin:6px 0">${lv.label}</div>
    <p class="muted" style="margin:8px 0 18px">${esc(lv.desc)}</p>
    <button class="btn gold block" onclick="renderLevel()">Ver minha trilha</button>
    <button class="btn ghost block" style="margin-top:8px" onclick="go('cards')">Estudar agora</button>
  </div>`;
}

/* =========================================================
   Helpers de UI
   ========================================================= */
function section(title,l){
  return `<div class="section-h">
    <div><div class="eyebrow">${l.flag} ${esc(l.name)}</div><h2>${title}</h2></div>
  </div>`;
}
function emptyBox(icon,title,desc,action,btn){
  return `<div class="card pad empty"><div class="big">${icon}</div>
    <h3 style="color:var(--petrol)">${title}</h3>
    <p class="muted" style="margin:8px 0 16px">${desc}</p>
    <button class="btn gold" onclick="${action}">${btn}</button></div>`;
}
function esc(s){return (s==null?'':String(s)).replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
let toastTimer=null;
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2200);}

/* go */
boot();
</script>
